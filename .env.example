# AWS Bedrock (required)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or use AWS_PROFILE / IAM role — standard boto3 credential chain

# Bedrock model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Embedder (required for RAG)
OLLAMA_HOST=http://localhost:11434

# Redshift (required for SQL Executor)
REDSHIFT_HOST=redshift.atlas.c2fo.io
REDSHIFT_PORT=5439
REDSHIFT_DB=atlas
REDSHIFT_USER=mops_user
REDSHIFT_PASSWORD=

# Data paths (defaults are relative to project root)
LANCEDB_URI=./data/lancedb
SQLITE_DB=./data/mops.db
LIBRARIAN_ENGINE_DIR=../engines/sql-librarian-engine-v1
PLAYBOOKS_DIR=../engines/sql-librarian-engine-v1/playbooks
KNOWLEDGE_DIR=./knowledge
RESULTS_DIR=./data/results

# User
USER_ID=mops
